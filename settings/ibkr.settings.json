{
  "permissions": {
    "allow": [
      "Bash(ibkr account*)",
      "Bash(ibkr positions*)",
      "Bash(ibkr quote*)",
      "Bash(ibkr calendar*)",
      "Bash(ibkr watch --list*)",
      "Bash(ibkr watch --watch*)",
      "Bash(ibkr chain*)",
      "Bash(ibkr history*)",
      "Bash(ibkr scan*)",
      "Bash(ibkr size*)",
      "Bash(ibkr breadth*)",
      "Bash(ibkr gamma*)",
      "Bash(ibkr regime*)",
      "Bash(ibkr trading status*)",
      "Bash(ibkr orders open*)",
      "Bash(ibkr order status*)",
      "Bash(ibkr order preview*)",
      "Bash(ibkr order place*)",
      "Bash(ibkr order modify*)",
      "Bash(ibkr order cancel*)",
      "Bash(ibkr purge --all*)",
      "Bash(ibkr purge execute*)",
      "Bash(ibkr purge restore*)",
      "Bash(ibkr status*)",
      "Bash(ibkr version*)"
    ],
    "deny": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/ibkr-pre-tool-use.sh\""
          }
        ]
      }
    ]
  }
}
