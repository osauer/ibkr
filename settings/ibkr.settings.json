{
  "permissions": {
    "allow": [
      "Bash(ibkr account*)",
      "Bash(ibkr positions*)",
      "Bash(ibkr quote*)",
      "Bash(ibkr chain*)",
      "Bash(ibkr history*)",
      "Bash(ibkr scan*)",
      "Bash(ibkr status*)",
      "Bash(ibkr version*)"
    ],
    "deny": [
      "Bash(ibkr order*)",
      "Bash(ibkr trade*)",
      "Bash(ibkr cancel*)",
      "Bash(ibkr * --live*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -e '.tool_input.command | test(\"\\\\bibkr\\\\s+(order|trade|cancel)\\\\b\")' >/dev/null && exit 2 || exit 0"
          }
        ]
      }
    ]
  }
}
