# Project execpolicy rules for IBKR work.
#
# These rules are intentionally narrower than a global `ibkr` allow rule. The
# hook in ../hooks/ibkr-pre-tool-use.sh handles cases that prefix rules cannot
# express, such as flags appearing after symbols.

prefix_rule(
    pattern = ["ibkr", ["status", "version", "account", "positions", "quote", "calendar", "watch", "chain", "history", "scan", "size", "technical", "market-events", "breadth", "gamma", "regime", "canary"]],
    decision = "allow",
    justification = "Read-only IBKR account, market-data, screen, regime, canary, and sizing commands are routine project work.",
    match = [
        "ibkr status --json",
        "ibkr quote AAPL --json",
        "ibkr market-events --symbol CRWV --json",
        "ibkr regime --json",
        "ibkr canary --json",
    ],
)

prefix_rule(
    pattern = ["ibkr", "order", ["preview", "status"]],
    decision = "allow",
    justification = "Preview/status order commands are non-submitting read surfaces.",
    match = [
        "ibkr order preview --symbol AAPL --action BUY --quantity 1 --json",
        "ibkr order status --json",
    ],
)

prefix_rule(
    pattern = ["ibkr", "orders", ["open", "history"]],
    decision = "allow",
    justification = "Open/history order commands are read-only journal surfaces.",
    match = [
        "ibkr orders open --json",
        "ibkr orders history --since 2026-06-18 --until 2026-06-19 --json",
    ],
)

prefix_rule(
    pattern = ["ibkr", "trading", "status"],
    decision = "allow",
    justification = "Trading status reports local capability and acknowledgements without placing orders.",
    match = [
        "ibkr trading status --json",
    ],
)

prefix_rule(
    pattern = ["ibkr", "proposals", ["status", "list", "refresh", "preview", "submit", "ignore"]],
    decision = "allow",
    justification = "Protection proposal surfaces are allowed at the prefix layer; preview/submit/ignore remain gated by the project hook and daemon trading policy.",
    match = [
        "ibkr proposals refresh --json",
        "ibkr proposals preview --key abc --revision sha256:abc --json",
        "ibkr proposals submit --key abc --revision sha256:abc --json",
    ],
)

prefix_rule(
    pattern = ["ibkr", "order", ["place", "submit", "execute", "modify", "cancel", "close"]],
    decision = "allow",
    justification = "Broker writes are allowed when the project hook confirms trading.status is paper/write-ready or live/write-ready; freeze, blocked, and unknown states remain blocked by hook/daemon gates.",
    match = [
        "ibkr order place --preview-token TOKEN --json",
        "ibkr order cancel ORDER_ID --json",
    ],
)

prefix_rule(
    pattern = ["ibkr", "opportunities", ["status", "list", "refresh", "preview", "exercise", "ignore"]],
    decision = "allow",
    justification = "Opportunity discovery is read-oriented; preview/exercise/ignore remain gated by the project hook and daemon trading policy.",
    match = [
        "ibkr opportunities status --json",
        "ibkr opportunities preview KEY REVISION --json",
        "ibkr opportunities exercise KEY REVISION --json",
    ],
)

prefix_rule(
    pattern = ["ibkr", "restart"],
    decision = "allow",
    justification = "The repo requires a CLI restart after installing daemon/CLI changes.",
    match = [
        "ibkr restart --timeout 15s",
        "ibkr restart --timeout 15s --json",
    ],
)

prefix_rule(
    pattern = ["make", ["help", "check", "smoke", "smoke-fast", "install", "restart-daemon", "app-check", "app-refresh", "app-refresh-smoke", "app-smoke", "app-lifecycle-smoke", "docs-check", "docs-regen", "test"]],
    decision = "allow",
    justification = "Standard project verification and local refresh commands.",
    match = [
        "make help",
        "make check",
        "make docs-check",
        "make smoke",
        "make smoke-fast",
        "make restart-daemon",
        "make app-refresh-smoke APP_SMOKE_BROWSER=webkit",
    ],
)

prefix_rule(
    pattern = ["ibkr", "purge", "--all"],
    decision = "allow",
    justification = "Purge execution is allowed when the project hook confirms trading.status is paper/write-ready or live/write-ready; freeze, blocked, and unknown states remain blocked by hook/daemon gates.",
    match = [
        "ibkr purge --all",
    ],
)

prefix_rule(
    pattern = ["ibkr", "purge", "execute"],
    decision = "allow",
    justification = "Purge execution is allowed when the project hook confirms trading.status is paper/write-ready or live/write-ready; freeze, blocked, and unknown states remain blocked by hook/daemon gates.",
    match = [
        "ibkr purge execute --all --json",
    ],
)

prefix_rule(
    pattern = ["ibkr", "purge", "restore"],
    decision = "allow",
    justification = "Restore preview is read-only; restore execution is allowed only when the project hook confirms trading.status is paper/write-ready or live/write-ready.",
    match = [
        "ibkr purge restore --all --json",
        "ibkr purge restore --all --execute --json",
    ],
)

prefix_rule(
    pattern = ["pkill", "-f"],
    decision = "prompt",
    justification = "Use 'ibkr restart --timeout 15s' for normal daemon restarts; pkill is only for broken/stuck daemon recovery.",
    match = [
        "pkill -f ibkr daemon",
        "pkill -f 'ibkr daemon'",
    ],
)
