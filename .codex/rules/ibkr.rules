# Project execpolicy rules for IBKR work.
#
# These rules are intentionally narrower than a global `ibkr` allow rule.
# Daemon authorization is the broker-write boundary; the project hook adds
# earlier, best-effort rejection for command shapes prefix rules cannot express.

prefix_rule(
    pattern = ["ibkr", ["status", "version", "account", "positions", "quote", "calendar", "chain", "history", "scan", "size", "technical", "market-events", "breadth", "gamma", "regime", "canary", "rules"]],
    decision = "allow",
    justification = "Read-only IBKR account, market-data, screen, regime, canary, and sizing commands are routine project work.",
    match = [
        "ibkr status --json",
        "ibkr quote AAPL --json",
        "ibkr market-events --symbol CRWV --json",
        "ibkr regime --json",
        "ibkr canary --json",
    ],
)

prefix_rule(
    pattern = ["ibkr", "order", ["preview", "status"]],
    decision = "allow",
    justification = "Preview/status order commands are non-submitting read surfaces.",
    match = [
        "ibkr order preview --symbol AAPL --action BUY --quantity 1 --json",
        "ibkr order status --json",
    ],
)

prefix_rule(
    pattern = ["ibkr", "orders", ["open", "history"]],
    decision = "allow",
    justification = "Open/history order commands are read-only journal surfaces.",
    match = [
        "ibkr orders open --json",
        "ibkr orders history --since 2026-06-18 --until 2026-06-19 --json",
    ],
)

prefix_rule(
    pattern = ["ibkr", "trading", "status"],
    decision = "allow",
    justification = "Trading status reports local capability and acknowledgements without placing orders.",
    match = [
        "ibkr trading status --json",
    ],
)

prefix_rule(
    pattern = ["ibkr", "proposals", ["status", "list", "refresh", "preview"]],
    decision = "allow",
    justification = "Protection proposal discovery and preview do not submit broker orders.",
    match = [
        "ibkr proposals refresh --json",
        "ibkr proposals preview --key abc --revision sha256:abc --json",
    ],
)

prefix_rule(
    pattern = ["ibkr", "proposals", ["submit", "reduce", "ignore"]],
    decision = "prompt",
    justification = "Proposal submit/reduce may reach broker writes, and ignore mutates local decision state; require a current-turn user decision.",
    match = [
        "ibkr proposals submit --key abc --revision sha256:abc --json",
        "ibkr proposals reduce AAPL --percent 25 --submit --json",
    ],
)

prefix_rule(
    pattern = ["ibkr", "order", ["place", "submit", "execute", "modify", "cancel"]],
    decision = "prompt",
    justification = "Broker writes require an explicit transaction-specific current-turn instruction in addition to hook and daemon gates.",
    match = [
        "ibkr order place --preview-token TOKEN --json",
        "ibkr order cancel ORDER_ID --json",
    ],
)

prefix_rule(
    pattern = ["ibkr", "opportunities", ["status", "list", "refresh", "preview"]],
    decision = "allow",
    justification = "Opportunity discovery and preview do not submit broker orders.",
    match = [
        "ibkr opportunities status --json",
        "ibkr opportunities preview KEY REVISION --json",
    ],
)

prefix_rule(
    pattern = ["ibkr", "opportunities", ["exercise", "ignore"]],
    decision = "prompt",
    justification = "Exercise reaches a broker write and ignore mutates local decision state; require a current-turn user decision.",
    match = [
        "ibkr opportunities exercise KEY REVISION --json",
    ],
)

prefix_rule(
    pattern = ["ibkr", "restart"],
    decision = "allow",
    justification = "The repo requires a CLI restart after installing daemon/CLI changes.",
    match = [
        "ibkr restart --timeout 15s",
        "ibkr restart --timeout 15s --json",
    ],
)

prefix_rule(
    pattern = ["make", ["help", "check", "app-check", "app-refresh", "app-refresh-smoke", "app-smoke", "app-lifecycle-smoke", "docs-check", "docs-regen", "test"]],
    decision = "allow",
    justification = "Offline verification and local app refresh commands.",
    match = [
        "make help",
        "make check",
        "make test",
        "make docs-check",
        "make app-refresh-smoke APP_SMOKE_BROWSER=webkit",
    ],
)

prefix_rule(
    pattern = ["make", ["install", "restart-daemon", "smoke", "smoke-fast"]],
    decision = "prompt",
    justification = "Installed-daemon and live-gateway targets need a current-turn human decision; headless delegates fail closed and run offline gates only (root AGENTS.md).",
    match = [
        "make install",
        "make restart-daemon",
        "make smoke",
        "make smoke-fast",
    ],
)

prefix_rule(
    pattern = ["ibkr", "purge", "--all"],
    decision = "prompt",
    justification = "Purge execution is a broker write and requires a transaction-specific current-turn instruction.",
    match = [
        "ibkr purge --all",
    ],
)

prefix_rule(
    pattern = ["ibkr", "purge", "execute"],
    decision = "prompt",
    justification = "Purge execution is a broker write and requires a transaction-specific current-turn instruction.",
    match = [
        "ibkr purge execute --all --json",
    ],
)

prefix_rule(
    pattern = ["ibkr", "purge", "restore"],
    decision = "prompt",
    justification = "Restore preview is read-only but the same prefix can carry --execute; require review at this boundary.",
    match = [
        "ibkr purge restore --all --json",
        "ibkr purge restore --all --execute --json",
    ],
)

prefix_rule(
    pattern = ["ibkr", "settings", "set"],
    decision = "forbidden",
    justification = "Runtime settings, freeze, and trading-limit changes are human-only in agent sessions.",
    match = [
        "ibkr settings set trading.freeze=true",
    ],
)

prefix_rule(
    pattern = ["ibkr", "daemon", ["purge", "reset", "wipe"]],
    decision = "forbidden",
    justification = "Destructive daemon maintenance is human-only in agent sessions.",
    match = [
        "ibkr daemon wipe",
    ],
)

prefix_rule(
    pattern = ["pkill", "-f"],
    decision = "prompt",
    justification = "Use 'ibkr restart --timeout 15s' for normal daemon restarts; pkill is only for broken/stuck daemon recovery.",
    match = [
        "pkill -f ibkr daemon",
        "pkill -f 'ibkr daemon'",
    ],
)
