# Project execpolicy rules for IBKR work.
#
# These rules are intentionally narrower than a global `ibkr` allow rule. The
# hook in ../hooks/ibkr-pre-tool-use.sh handles cases that prefix rules cannot
# express, such as flags appearing after symbols.

prefix_rule(
    pattern = ["ibkr", ["status", "version", "account", "positions", "quote", "calendar", "watch", "chain", "history", "scan", "size", "technical", "market-events", "breadth", "gamma", "regime", "canary"]],
    decision = "allow",
    justification = "Read-only IBKR account, market-data, screen, regime, canary, and sizing commands are routine project work.",
    match = [
        "ibkr status --json",
        "ibkr quote AAPL --json",
        "ibkr market-events --symbol CRWV --json",
        "ibkr regime --json",
        "ibkr canary --json",
    ],
)

prefix_rule(
    pattern = ["ibkr", "order", ["preview", "status"]],
    decision = "allow",
    justification = "Preview/status order commands are non-submitting read surfaces.",
    match = [
        "ibkr order preview --symbol AAPL --action BUY --quantity 1 --json",
        "ibkr order status --json",
    ],
)

prefix_rule(
    pattern = ["ibkr", "orders", ["open", "status"]],
    decision = "allow",
    justification = "Open/status order commands are read-only journal surfaces.",
    match = [
        "ibkr orders open --json",
        "ibkr orders status --json",
    ],
)

prefix_rule(
    pattern = ["ibkr", "trading", "status"],
    decision = "allow",
    justification = "Trading status reports local capability and acknowledgements without placing orders.",
    match = [
        "ibkr trading status --json",
    ],
)

prefix_rule(
    pattern = ["ibkr", "proposals", ["snapshot", "refresh", "preview"]],
    decision = "allow",
    justification = "Protection proposal snapshot/refresh/preview are read-only or preview-backed safety surfaces; submit remains forbidden.",
    match = [
        "ibkr proposals refresh --json",
        "ibkr proposals preview --key abc --revision sha256:abc --json",
    ],
)

prefix_rule(
    pattern = ["ibkr", "restart"],
    decision = "allow",
    justification = "The repo requires a CLI restart after installing daemon/CLI changes.",
    match = [
        "ibkr restart --timeout 15s",
        "ibkr restart --timeout 15s --json",
    ],
)

prefix_rule(
    pattern = ["make", ["help", "check", "smoke", "install", "restart-daemon", "app-check", "app-refresh", "app-refresh-smoke", "app-smoke", "app-lifecycle-smoke", "docs-check", "docs-regen", "test"]],
    decision = "allow",
    justification = "Standard project verification and local refresh commands.",
    match = [
        "make help",
        "make check",
        "make docs-check",
        "make smoke",
        "make restart-daemon",
        "make app-refresh-smoke APP_SMOKE_BROWSER=webkit",
    ],
)

prefix_rule(
    pattern = ["ibkr", "proposals", "submit"],
    decision = "prompt",
    justification = "Protection proposal submit can transmit broker orders. The project hook permits it only when trading.status reports a ready paper gate; live and unknown routes stay blocked.",
    match = [
        "ibkr proposals submit --key abc --revision sha256:abc",
    ],
)

prefix_rule(
    pattern = ["ibkr", ["trade", "trades", "submit", "place", "cancel", "close", "modify", "transmit"]],
    decision = "prompt",
    justification = "Broker mutation verbs are allowed for Codex only through the project hook's daemon-reported paper gate. Live and unknown routes stay blocked.",
    match = [
        "ibkr submit --token abc",
        "ibkr cancel 123",
    ],
)

prefix_rule(
    pattern = ["ibkr", "order", ["place", "submit", "cancel", "close", "modify", "transmit", "execute"]],
    decision = "prompt",
    justification = "Order mutation verbs pass only when the project hook verifies trading.status is a ready paper route with the matching capability. Live and unknown routes stay blocked.",
    match = [
        "ibkr order submit --token abc",
        "ibkr order cancel 123",
    ],
    not_match = [
        "ibkr order preview --symbol AAPL --action BUY --quantity 1",
    ],
)

prefix_rule(
    pattern = ["ibkr", "orders", ["place", "submit", "cancel", "close", "modify", "transmit", "execute"]],
    decision = "prompt",
    justification = "Order journal mutation verbs pass only when the project hook verifies trading.status is a ready paper route with the matching capability. Live and unknown routes stay blocked.",
    match = [
        "ibkr orders cancel 123",
    ],
)

prefix_rule(
    pattern = ["ibkr", "trading", ["enable", "disable", "submit", "place", "cancel", "close", "modify", "transmit", "execute"]],
    decision = "prompt",
    justification = "Trading capability changes stay operator-owned; broker mutation verbs pass only when the project hook verifies a ready paper route. Live and unknown routes stay blocked.",
    match = [
        "ibkr trading enable --ack-live",
    ],
)

prefix_rule(
    pattern = ["ibkr", "purge", "--all"],
    decision = "prompt",
    justification = "Purge execution is destructive-adjacent; require explicit human approval and prefer dry-run/status first.",
    match = [
        "ibkr purge --all",
    ],
)

prefix_rule(
    pattern = ["pkill", "-f"],
    decision = "prompt",
    justification = "Use 'ibkr restart --timeout 15s' for normal daemon restarts; pkill is only for broken/stuck daemon recovery.",
    match = [
        "pkill -f ibkr daemon",
        "pkill -f 'ibkr daemon'",
    ],
)
