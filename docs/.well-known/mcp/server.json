{
  "name": "ibkr",
  "title": "ibkr",
  "description": "Local read-only Interactive Brokers (IBKR) MCP server, CLI, and Go TWS API for account and market analysis through IB Gateway or TWS.",
  "homepage": "https://osauer.dev/ibkr/",
  "repository": "https://github.com/osauer/ibkr",
  "license": "MIT",
  "version": "1.0.9",
  "transport": {
    "type": "stdio",
    "command": "ibkr",
    "args": ["mcp"]
  },
  "install": {
    "shell": "curl -fsSL https://raw.githubusercontent.com/osauer/ibkr/main/install.sh | sh",
    "claude_desktop": "ibkr setup claude-desktop"
  },
  "requires": [
    "IB Gateway 10.37+ or TWS running locally",
    "IBKR Pro account with TWS API access"
  ],
  "compatible_hosts": [
    "Claude Desktop",
    "Claude Code",
    "Cursor",
    "Continue",
    "Zed",
    "any local stdio MCP host"
  ],
  "capabilities": [
    "account summary",
    "positions and exposure",
    "stock and ETF quotes",
    "option chains",
    "daily historical bars",
    "market scanners",
    "fixed-fractional position sizing",
    "S&P 500 breadth",
    "SPY+SPX dealer gamma",
    "risk-regime dashboard",
    "stock and ETF quote resources"
  ],
  "safety": {
    "order_entry_surface": false,
    "can_place_orders": false,
    "can_modify_orders": false,
    "can_cancel_orders": false,
    "summary": "The bundled CLI and MCP server expose account and market data, but no order-entry interface."
  },
  "keywords": [
    "Interactive Brokers",
    "IBKR",
    "TWS API",
    "IB Gateway",
    "MCP server",
    "Claude Desktop",
    "Claude Code",
    "Cursor",
    "Zed",
    "Go"
  ]
}
