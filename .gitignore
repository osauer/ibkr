# Build artifacts
/bin/
/dist/
*.log

# Cache files
*.bak
*.tmp
__pycache__/
*.pyc

# Cloudflare Worker local artifacts
cloudflare/remote-relay/node_modules/
cloudflare/remote-relay/.wrangler/
cloudflare/remote-relay/.dev.vars

# OS / editor noise
**/.DS_Store
.idea/
.vscode/

# Local test outputs
/test/integration/run-*/

# Personal Claude Code state (project-shared settings would go in settings.json)
.claude/settings.local.json
.claude/worktrees/
.claude/scheduled_tasks.lock
CLAUDE.md
/.claude_memory.md

# Claude Code agent worktrees — created at the repo root with
# <adjective>-<noun>-<6 hex chars> names (e.g. optimistic-newton-2eb23f/)
/*-*-[0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f]/

# Working artefacts that aren't part of the source tree. Root HTML is a
# scratch page by definition — real pages live under docs/ (GitHub Pages
# serves https://osauer.dev/ibkr/ from /docs on main, so generated page
# artifacts there must stay visible to git) or web/. Scratch pages can
# carry real account figures (the 2026-06-11 buying_power_lab.html leak),
# so git refusing the add is the first line of defense;
# scripts/check-no-account-data.sh in `make check` is the backstop.
/*.html
*lab*.html
*scratch*
/HANDOFF.md
tmp/
